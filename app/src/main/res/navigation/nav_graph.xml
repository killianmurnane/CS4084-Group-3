<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.cs4084_group_3.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/nav_workouts"
        android:name="com.example.cs4084_group_3.WorkoutsFragment"
        android:label="Workouts">
        <action
            android:id="@+id/action_workouts_to_activeWorkout"
            app:destination="@id/activeWorkout"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/activeWorkout"
        android:name="com.example.cs4084_group_3.WorkoutActiveFragment"
        android:label="Active Workout">
        <argument
            android:name="workoutName"
            app:argType="string"
            android:defaultValue="Workout" />
    </fragment>

    <fragment
        android:id="@+id/nav_progress"
        android:name="com.example.cs4084_group_3.ProgressFragment"
        android:label="Progress" />

</navigation>
